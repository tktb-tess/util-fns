{
  "name": "@tktb-tess/util-fns",
  "version": "0.13.0",
  "description": "Utility functions for personal use",
  "files": [
    "dist"
  ],
  "type": "module",
  "author": "Tessyrrhaqt",
  "license": "MIT",
  "browser": "./dist/iife/bundle.min.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
