      "types": "./dist/esm/base64.d.ts",
      "import": "./dist/esm/base64.js"
    },
    "./compression": {
      "types": "./dist/esm/compression.d.ts",
      "import": "./dist/esm/compression.js"
    },
    "./equality": {
      "types": "./dist/esm/equality.d.ts",
      "import": "./dist/esm/equality.js"
    },
    "./fraction": {
      "types": "./dist/esm/fraction.d.ts",
      "import": "./dist/esm/fraction.js"
    },
    "./leb128": {
      "types": "./dist/esm/leb128.d.ts",
      "import": "./dist/esm/leb128.js"
    },
    "./math": {
      "types": "./dist/esm/math.d.ts",
