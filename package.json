    "./random": {
      "types": "./dist/esm/random.d.ts",
      "import": "./dist/esm/random.js"
    },
    "./util": {
      "types": "./dist/esm/util.d.ts",
      "import": "./dist/esm/util.js"
    },
    "./xoshiro_minimal": {
      "types": "./dist/esm/xoshiro_minimal.d.ts",
      "import": "./dist/esm/xoshiro_minimal.js"
    }
