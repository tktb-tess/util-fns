{
  "name": "@tktb-tess/util-fns",
  "version": "0.12.5",
  "description": "Utility functions for personal use",
  "files": [
    "dist"
  ],
  "type": "module",
  "author": "Tessyrrhaqt",
  "license": "MIT",
  "browser": "./dist/bundle.min.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./async_worker": {
      "types": "./dist/esm/async_worker.d.ts",
      "import": "./dist/esm/async_worker.js"
    },
    "./baillie_psw": {
      "types": "./dist/esm/baillie_psw.d.ts",
      "import": "./dist/esm/baillie_psw.js"
    },
    "./fraction": {
      "types": "./dist/esm/fraction.d.ts",
      "import": "./dist/esm/fraction.js"
    },
    "./leb128": {
      "types": "./dist/esm/leb128.d.ts",
      "import": "./dist/esm/leb128.js"
    },
    "./math": {
      "types": "./dist/esm/math.d.ts",
      "import": "./dist/esm/math.js"
    },
    "./named_error": {
      "types": "./dist/esm/named_error.d.ts",
      "import": "./dist/esm/named_error.js"
    },
    "./pcg_minimal": {
      "types": "./dist/esm/pcg_minimal.d.ts",
      "import": "./dist/esm/pcg_minimal.js"
    },
    "./random": {
      "types": "./dist/esm/random.d.ts",
      "import": "./dist/esm/random.js"
    },
    "./u8arr_ext": {
      "types": "./dist/esm/u8arr_ext.d.ts",
      "import": "./dist/esm/u8arr_ext.js"
    },
    "./util": {
      "types": "./dist/esm/util.d.ts",
      "import": "./dist/esm/util.js"
    },
    "./xoshiro_minimal": {
      "types": "./dist/esm/xoshiro_minimal.d.ts",
      "import": "./dist/esm/xoshiro_minimal.js"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tktb-tess/util-fns.git"
  },
  "homepage": "https://github.com/tktb-tess/util-fns/blob/main/README.md",
  "scripts": {
    "dev": "vite",
    "build:esm": "vite build",
    "build:iife": "vite build --config vite.config.iife.ts",
    "build": "pnpm build:esm && pnpm build:iife",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0"
}
